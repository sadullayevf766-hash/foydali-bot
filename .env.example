# Bu faylni .env deb nusxalang va qiymatlarni to'ldiring.
# Windows'da: copy .env.example .env

# BotFather'dan olingan token (majburiy)
BOT_TOKEN=

# Sizning Telegram ID raqamingiz (admin huquqlari uchun).
# Bilish uchun @userinfobot ga yozing.
ADMIN_ID=

# Ixtiyoriy sozlamalar (default qiymatlar yetarli)
FREE_DAILY_LIMIT=5
PREMIUM_PRICE_STARS=150
PREMIUM_DAYS=30
